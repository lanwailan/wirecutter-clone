---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCard from '../components/ReviewCard.tsx';
import { getCollection } from 'astro:content';

// 获取所有评测
const reviews = await getCollection('reviews');
---

<BaseLayout title="Product Reviews - Wirecutter Clone">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Product Reviews</h1>
    <p class="text-gray-600 mb-8">Expert reviews and buying advice for the best products</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <ReviewCard
          title={review.data.title}
          category={review.data.category}
          rating={review.data.rating}
          pros={review.data.pros}
          cons={review.data.cons}
          slug={review.slug}
          image={review.data.image}
        />
      ))}
    </div>
    
    {reviews.length === 0 && (
      <div class="text-center py-12">
        <h2 class="text-xl font-semibold mb-2">No reviews yet</h2>
        <p class="text-gray-600">Check back soon for expert product reviews!</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
.container {
  max-width: 1200px;
}
</style>