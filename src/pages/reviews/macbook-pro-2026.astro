---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RatingStars from '@/components/RatingStars.tsx';

const lang = 'en';
const review = {
  title: "MacBook Pro 16-inch (2026) Review: Still the King of Pro Laptops",
  description: "After 3 months of intensive testing, we evaluate Apple's latest flagship laptop for creative professionals and developers.",
  productCategory: "Laptops",
  rating: 4.8,
  ratingCount: 342,
  price: 2499,
  priceCurrency: "USD",
  keyFeatures: [
    "M3 Pro chip with 12-core CPU, 18-core GPU",
    "16.2-inch Liquid Retina XDR display",
    "32GB unified memory",
    "1TB SSD storage",
    "Up to 22 hours battery life"
  ],
  pros: [
    "Exceptional performance for creative workloads",
    "Stunning mini-LED display with ProMotion",
    "Industry-leading battery life",
    "Excellent build quality and design",
    "Improved thermal management"
  ],
  cons: [
    "Very expensive, especially with upgrades",
    "Limited port selection (still only Thunderbolt/USB-C)",
    "Heavier than some competing workstations",
    "Notch on display may bother some users"
  ],
  specifications: {
    "Processor": "Apple M3 Pro (12-core)",
    "Graphics": "18-core GPU",
    "Memory": "32GB unified",
    "Storage": "1TB SSD",
    "Display": "16.2-inch Liquid Retina XDR",
    "Resolution": "3456 × 2234",
    "Battery": "100Wh, up to 22 hours",
    "Weight": "2.15 kg (4.7 lbs)",
    "Ports": "3× Thunderbolt 4, HDMI, SDXC, MagSafe 3, headphone jack"
  },
  author: "Alex Chen",
  publishDate: new Date("2026-03-15"),
  readTime: 15,
  coverImage: "https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=1200&auto=format&fit=crop"
};
---

<BaseLayout 
  title={`${review.title} - Wirecutter Clone`}
  description={review.description}
  lang={lang}
>
  <div class="container mx-auto px-4 py-8">
    <!-- 面包屑导航 -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/en" class="hover:text-blue-600">Home</a> &gt;
      <span class="text-gray-800">{review.title}</span>
    </nav>

    <!-- 评测标题和元信息 -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{review.title}</h1>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <div class="flex items-center">
          <RatingStars rating={review.rating} />
          <span class="ml-2 font-semibold">{review.rating}/5</span>
          <span class="ml-2 text-gray-600">({review.ratingCount} reviews)</span>
        </div>
        <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
          {review.productCategory}
        </span>
        <span class="text-gray-600">{review.publishDate.toLocaleDateString('en-US')}</span>
        <span class="text-gray-600">• {review.readTime} min read</span>
      </div>
      
      {review.coverImage && (
        <img 
          src={review.coverImage} 
          alt={review.title}
          class="w-full h-64 md:h-96 object-cover rounded-lg mb-6"
        />
      )}
    </div>

    <!-- 摘要 -->
    <div class="bg-gray-50 p-6 rounded-lg mb-8">
      <h2 class="text-xl font-bold mb-3">Summary</h2>
      <p class="text-gray-700">{review.description}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- 主要内容 -->
      <div class="lg:col-span-2">
        <div class="prose max-w-none">
          <h2>Detailed Review</h2>
          
          <h3>Performance</h3>
          <p>The Apple M3 Pro chip delivers exceptional performance for professional workloads. In our tests, video rendering was 40% faster than the previous generation, and code compilation times were significantly reduced.</p>
          
          <h3>Display Quality</h3>
          <p>The 16.2-inch Liquid Retina XDR display is simply stunning. With 1000 nits sustained brightness and 1600 nits peak, it's perfect for HDR content creation and consumption.</p>
          
          <h3>Battery Life</h3>
          <p>Apple's claims of 22-hour battery life hold up in real-world usage. We consistently got 18-20 hours of mixed use, making this one of the longest-lasting pro laptops available.</p>
          
          <h3>Build and Design</h3>
          <p>The aluminum unibody construction feels premium and durable. While it's not the lightest workstation, the build quality justifies the weight for most professional users.</p>
        </div>
      </div>

      <!-- 侧边栏 -->
      <div class="space-y-6">
        <!-- 优缺点 -->
        <div class="bg-white border rounded-lg p-6">
          <h3 class="text-lg font-bold mb-4">Pros & Cons</h3>
          
          <div class="mb-4">
            <h4 class="font-semibold text-green-700 mb-2">Pros</h4>
            <ul class="list-disc pl-5 space-y-1">
              {review.pros.map((pro, index) => (
                <li key={index} class="text-gray-700">{pro}</li>
              ))}
            </ul>
          </div>
          
          <div>
            <h4 class="font-semibold text-red-700 mb-2">Cons</h4>
            <ul class="list-disc pl-5 space-y-1">
              {review.cons.map((con, index) => (
                <li key={index} class="text-gray-700">{con}</li>
              ))}
            </ul>
          </div>
        </div>

        <!-- 关键特性 -->
        <div class="bg-white border rounded-lg p-6">
          <h3 class="text-lg font-bold mb-4">Key Features</h3>
          <ul class="space-y-2">
            {review.keyFeatures.map((feature, index) => (
              <li key={index} class="flex items-start">
                <span class="text-green-500 mr-2 mt-1">✓</span>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- 规格 -->
        <div class="bg-white border rounded-lg p-6">
          <h3 class="text-lg font-bold mb-4">Specifications</h3>
          <dl class="space-y-2">
            {Object.entries(review.specifications).map(([key, value]) => (
              <div class="flex justify-between">
                <dt class="text-gray-600">{key}:</dt>
                <dd class="font-medium">{value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <!-- 价格 -->
        <div class="bg-white border rounded-lg p-6">
          <h3 class="text-lg font-bold mb-4">Price</h3>
          <div class="text-2xl font-bold text-gray-900 mb-2">
            {review.priceCurrency} {review.price.toFixed(2)}
          </div>
          <p class="text-gray-600 text-sm">
            Base model price. Configured models with more memory/storage cost more.
          </p>
        </div>
      </div>
    </div>

    <!-- 返回链接 -->
    <div class="mt-12 pt-8 border-t text-center">
      <a href="/en" class="text-blue-600 hover:text-blue-700 font-medium">
        ← Back to Home
      </a>
    </div>
  </div>
</BaseLayout>

<style>
.container {
  max-width: 1200px;
}
.prose h2 {
  font-size: 1.5rem;
  font-weight: bold;
  margin-top: 2rem;
  margin-bottom: 1rem;
}
.prose h3 {
  font-size: 1.25rem;
  font-weight: bold;
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
}
.prose p {
  margin-bottom: 1rem;
  line-height: 1.6;
}
</style>