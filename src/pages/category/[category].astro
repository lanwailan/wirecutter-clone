---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReviewCard from '@/components/ReviewCard.tsx';

export async function getStaticPaths() {
  return [
    { params: { category: 'electronics' } },
    { params: { category: 'home-garden' } },
    { params: { category: 'kitchen' } },
    { params: { category: 'sleep' } },
    { params: { category: 'health-fitness' } },
  ];
}

const { category } = Astro.params;

// Mock data based on category
const getCategoryData = (category: string) => {
  const data: Record<string, any> = {
    electronics: {
      title: 'Electronics',
      description: 'Expert reviews on laptops, smartphones, headphones, and all things tech.',
      icon: '💻',
      reviews: [
        {
          id: '1',
          title: 'The Best Wireless Earbuds for 2026',
          excerpt: 'We tested 30 pairs of wireless earbuds to find the best options for sound quality, comfort, and battery life.',
          category: 'Audio',
          rating: 4.7,
          author: 'Sarah Miller',
          date: '2026-03-14',
          readTime: '9 min',
          tags: ['Noise Cancelling', 'Budget'],
        },
        {
          id: '2',
          title: 'Top Gaming Monitors Under $500',
          excerpt: 'High refresh rates, low response times, and vibrant colors - we found the best gaming monitors for every budget.',
          category: 'Gaming',
          rating: 4.5,
          author: 'James Wilson',
          date: '2026-03-12',
          readTime: '11 min',
          tags: ['144Hz+', 'G-Sync'],
        },
        {
          id: '3',
          title: 'Smartphone Camera Comparison 2026',
          excerpt: 'Which phone takes the best photos? We put the latest flagships through rigorous camera testing.',
          category: 'Smartphones',
          rating: 4.8,
          author: 'Lisa Park',
          date: '2026-03-10',
          readTime: '14 min',
          tags: ['Camera', 'Comparison'],
        },
      ],
      subcategories: [
        { name: 'Laptops', count: 42 },
        { name: 'Smartphones', count: 38 },
        { name: 'Headphones', count: 31 },
        { name: 'Monitors', count: 27 },
        { name: 'Tablets', count: 23 },
        { name: 'Smart Home', count: 35 },
      ],
    },
    'home-garden': {
      title: 'Home & Garden',
      description: 'Everything for your home - from furniture to gardening tools and home improvement.',
      icon: '🏠',
      reviews: [
        {
          id: '1',
          title: 'Best Robot Vacuums for Pet Hair',
          excerpt: 'We tested robot vacuums specifically for homes with pets to find which ones handle fur the best.',
          category: 'Cleaning',
          rating: 4.6,
          author: 'Emma Chen',
          date: '2026-03-13',
          readTime: '8 min',
          tags: ['Pets', 'Automation'],
        },
      ],
      subcategories: [
        { name: 'Furniture', count: 28 },
        { name: 'Cleaning', count: 32 },
        { name: 'Gardening', count: 24 },
        { name: 'Lighting', count: 19 },
        { name: 'Storage', count: 21 },
        { name: 'Decor', count: 26 },
      ],
    },
  };

  return data[category] || {
    title: category.charAt(0).toUpperCase() + category.slice(1),
    description: `Product reviews and buying guides for ${category}.`,
    icon: '📦',
    reviews: [],
    subcategories: [],
  };
};

const categoryData = getCategoryData(category);
---

<BaseLayout 
  title={`${categoryData.title} - Wirecutter Clone`}
  description={categoryData.description}
>
  <!-- Category Header -->
  <section class="bg-gradient-to-r from-gray-50 to-white section-padding">
    <div class="container-custom">
      <div class="flex items-center space-x-4 mb-6">
        <span class="text-4xl">{categoryData.icon}</span>
        <div>
          <h1 class="heading-1">{categoryData.title}</h1>
          <p class="text-gray-700 text-lg mt-2">{categoryData.description}</p>
        </div>
      </div>
      
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-600 mb-8">
        <a href="/" class="hover:text-primary-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900 font-medium">{categoryData.title}</span>
      </nav>
    </div>
  </section>

  <div class="container-custom section-padding">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar - Subcategories -->
      <aside class="lg:col-span-1">
        <div class="card sticky top-24">
          <h3 class="heading-3 mb-4">Subcategories</h3>
          <ul class="space-y-2">
            {categoryData.subcategories.map((subcat: any) => (
              <li>
                <a
                  href={`/category/${category}/${subcat.name.toLowerCase()}`}
                  class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-gray-50 transition-colors"
                >
                  <span class="text-gray-700">{subcat.name}</span>
                  <span class="text-sm text-gray-500 bg-gray-100 px-2 py-1 rounded">
                    {subcat.count}
                  </span>
                </a>
              </li>
            ))}
          </ul>

          <div class="mt-8 pt-6 border-t border-gray-200">
            <h4 class="font-semibold text-gray-900 mb-3">Filter by</h4>
            <div class="space-y-3">
              <div>
                <label class="flex items-center">
                  <input type="checkbox" class="rounded text-primary-600" />
                  <span class="ml-2 text-gray-700">Top Picks</span>
                </label>
              </div>
              <div>
                <label class="flex items-center">
                  <input type="checkbox" class="rounded text-primary-600" />
                  <span class="ml-2 text-gray-700">Budget Options</span>
                </label>
              </div>
              <div>
                <label class="flex items-center">
                  <input type="checkbox" class="rounded text-primary-600" />
                  <span class="ml-2 text-gray-700">Editor\'s Choice</span>
                </label>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content - Reviews -->
      <main class="lg:col-span-3">
        <div class="flex items-center justify-between mb-8">
          <h2 class="heading-2">Latest Reviews</h2>
          <div class="flex items-center space-x-4">
            <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
              <option>Sort by: Newest</option>
              <option>Sort by: Rating</option>
              <option>Sort by: Popular</option>
            </select>
          </div>
        </div>

        {categoryData.reviews.length > 0 ? (
          <div class="space-y-6">
            {categoryData.reviews.map((review: any) => (
              <ReviewCard {...review} />
            ))}
          </div>
        ) : (
          <div class="text-center py-12">
            <div class="text-6xl mb-4">📝</div>
            <h3 class="heading-3 mb-2">No Reviews Yet</h3>
            <p class="text-gray-600">
              We're currently testing products in this category. Check back soon!
            </p>
          </div>
        )}

        <!-- Pagination -->
        {categoryData.reviews.length > 0 && (
          <div class="mt-12 flex justify-center">
            <nav class="flex items-center space-x-2">
              <button class="px-3 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                Previous
              </button>
              <button class="px-3 py-2 bg-primary-600 text-white rounded-lg">1</button>
              <button class="px-3 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                2
              </button>
              <button class="px-3 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                3
              </button>
              <span class="px-3 py-2">...</span>
              <button class="px-3 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                Next
              </button>
            </nav>
          </div>
        )}

        <!-- Category Description -->
        <div class="mt-12 card">
          <h3 class="heading-3 mb-4">About {categoryData.title} Reviews</h3>
          <div class="prose max-w-none">
            <p>
              Our {categoryData.title.toLowerCase()} reviews are based on extensive testing by our team of experts. 
              We evaluate each product based on performance, durability, value for money, and user experience.
            </p>
            <p>
              All products are purchased independently by our team - we never accept free samples or 
              payment for reviews. Our goal is to provide unbiased, data-driven recommendations you can trust.
            </p>
            <p>
              Have a question about a specific product? Check our FAQ or contact our review team directly.
            </p>
          </div>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>