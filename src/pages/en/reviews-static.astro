---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReviewCard from '@/components/ReviewCard.tsx';
import { getCollection } from 'astro:content';

const lang = 'en';

// 获取所有英语评测
const allReviews = await getCollection('reviews');
const englishReviews = allReviews.filter(review => review.data.lang === lang);

// 静态评测数据（确保至少有一个）
const staticReviews = englishReviews.length > 0 ? englishReviews : [
  {
    slug: 'macbook-pro-2026',
    data: {
      title: 'MacBook Pro 16-inch (2026) Review',
      productCategory: 'Laptops',
      rating: 4.8,
      pros: ['Exceptional performance', 'Stunning display', 'Long battery life'],
      cons: ['Expensive', 'Limited ports'],
      coverImage: 'https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=800&auto=format&fit=crop',
      description: 'The best pro laptop for creative work'
    }
  }
];
---

<BaseLayout 
  title="Product Reviews - Wirecutter Clone"
  description="Browse all our expert product reviews and buying advice."
  lang={lang}
>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Product Reviews</h1>
    <p class="text-gray-600 mb-8">
      Expert reviews and buying advice for the best products.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {staticReviews.map((review) => (
        <ReviewCard
          title={review.data.title}
          category={review.data.productCategory}
          rating={review.data.rating}
          pros={review.data.pros.slice(0, 2)}
          cons={review.data.cons.slice(0, 1)}
          slug={`/en/reviews/${review.slug}`}
          image={review.data.coverImage}
          lang={lang}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.container {
  max-width: 1200px;
}
</style>