---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReviewCard from '@/components/ReviewCard.tsx';
import { getCollection, filterByLang, getDefaultLang } from '@/content/config';

const lang = 'en'; // 英语

// 获取英语内容
const allReviews = await getCollection('reviews');
const englishReviews = filterByLang(allReviews, lang).slice(0, 6);

const allCategories = await getCollection('categories');
const englishCategories = filterByLang(allCategories, lang);

// 特色分类
const featuredCategories = englishCategories.filter(cat => cat.data.featured).slice(0, 4);
---

<BaseLayout 
  title="Wirecutter Clone - Product Reviews You Can Trust"
  description="Expert product reviews, buying guides, and recommendations. Find the best products for your needs."
  lang={lang}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-50 to-indigo-50 py-12 md:py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Product Reviews You Can <span class="text-primary-600">Trust</span>
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
        Our team of experts tests and reviews thousands of products to help you make the best buying decisions.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/en/reviews" class="btn-primary">
          Browse Reviews
        </a>
        <a href="#categories" class="btn-secondary">
          Explore Categories
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Reviews -->
  <section class="py-12">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold">Featured Reviews</h2>
        <a href="/en/reviews" class="text-primary-600 hover:text-primary-700 font-medium">
          View All Reviews →
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {englishReviews.map((review) => (
          <ReviewCard
            title={review.data.title}
            category={review.data.productCategory}
            rating={review.data.rating}
            pros={review.data.pros.slice(0, 2)}
            cons={review.data.cons.slice(0, 1)}
            slug={`/en/reviews/${review.slug}`}
            image={review.data.coverImage}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section id="categories" class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-10">Browse by Category</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {featuredCategories.map((category) => (
          <a 
            href={`/en/category/${category.data.slug}`}
            class="bg-white rounded-xl p-6 text-center shadow-sm hover:shadow-md transition-shadow border border-gray-100"
          >
            <div class="text-3xl mb-3">{category.data.icon || '📱'}</div>
            <h3 class="font-bold text-lg mb-2">{category.data.name}</h3>
            <p class="text-gray-600 text-sm">{category.data.description}</p>
            <div class="mt-4 text-sm text-gray-500">
              {category.data.reviewCount} reviews
            </div>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-10">
        <a href="/en/categories" class="text-primary-600 hover:text-primary-700 font-medium">
          View All Categories →
        </a>
      </div>
    </div>
  </section>

  <!-- Why Trust Us -->
  <section class="py-12">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-10">Why Trust Our Reviews?</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🔬</span>
          </div>
          <h3 class="font-bold text-xl mb-3">Rigorous Testing</h3>
          <p class="text-gray-600">
            We spend hundreds of hours testing each product in real-world conditions.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🤝</span>
          </div>
          <h3 class="font-bold text-xl mb-3">No Sponsorships</h3>
          <p class="text-gray-600">
            We buy all products ourselves and never accept payment for reviews.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🔄</span>
          </div>
          <h3 class="font-bold text-xl mb-3">Regular Updates</h3>
          <p class="text-gray-600">
            We continuously update our reviews as new products are released.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.container {
  max-width: 1200px;
}
.btn-primary {
  @apply bg-primary-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-700 transition-colors;
}
.btn-secondary {
  @apply bg-white text-primary-600 border border-primary-600 px-6 py-3 rounded-lg font-medium hover:bg-primary-50 transition-colors;
}
</style>