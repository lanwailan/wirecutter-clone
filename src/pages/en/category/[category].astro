---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReviewCard from '@/components/ReviewCard.tsx';
import { getCollection } from 'astro:content';

const lang = 'en';

// 导出 getStaticPaths 函数
export async function getStaticPaths() {
  const allCategories = await getCollection('categories');
  const englishCategories = allCategories.filter(cat => cat.data.lang === lang);
  
  return englishCategories.map((category) => ({
    params: { 
      category: category.data.slug,
      lang: lang
    },
    props: { 
      category,
      lang
    },
  }));
}

// 通过 props 接收数据
const { category, lang: pageLang } = Astro.props;

// 获取该分类下的所有英语评测
const allReviews = await getCollection('reviews');
const categoryReviews = allReviews
  .filter(review => review.data.lang === pageLang)
  .filter(review => review.data.productCategory === category.data.name)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout 
  title={`${category.data.name} Reviews - Wirecutter Clone`}
  description={category.data.description}
  lang={pageLang}
>
  <div class="container mx-auto px-4 py-8">
    <!-- 面包屑导航 -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/en" class="hover:text-blue-600">Home</a> &gt;
      <a href="/en/reviews" class="hover:text-blue-600">Reviews</a> &gt;
      <span class="text-gray-800">{category.data.name}</span>
    </nav>

    <!-- 分类标题 -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        {category.data.icon && (
          <div class="text-4xl">{category.data.icon}</div>
        )}
        <div>
          <h1 class="text-3xl md:text-4xl font-bold">{category.data.name}</h1>
          <p class="text-gray-600 mt-2">{category.data.description}</p>
        </div>
      </div>
      
      <div class="flex flex-wrap gap-4 text-sm text-gray-600">
        <div class="bg-gray-100 px-3 py-1 rounded-full">
          {categoryReviews.length} reviews
        </div>
        {category.data.subcategories.length > 0 && (
          <div class="flex flex-wrap gap-2">
            <span class="font-medium">Subcategories:</span>
            {category.data.subcategories.slice(0, 3).map((subcat) => (
              <span class="bg-blue-50 text-blue-700 px-2 py-1 rounded">
                {subcat}
              </span>
            ))}
            {category.data.subcategories.length > 3 && (
              <span class="text-gray-500">
                +{category.data.subcategories.length - 3} more
              </span>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- 评测列表 -->
    {categoryReviews.length > 0 ? (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
          {categoryReviews.map((review) => (
            <ReviewCard
              title={review.data.title}
              category={review.data.productCategory}
              rating={review.data.rating}
              pros={review.data.pros.slice(0, 2)}
              cons={review.data.cons.slice(0, 1)}
              slug={`/en/reviews/${review.slug}`}
              image={review.data.coverImage}
              lang={pageLang}
            />
          ))}
        </div>

        <!-- 分页提示 -->
        {categoryReviews.length > 12 && (
          <div class="text-center py-8">
            <p class="text-gray-600 mb-4">
              Showing 12 of {categoryReviews.length} reviews
            </p>
            <button class="btn-primary">
              Load More Reviews
            </button>
          </div>
        )}
      </>
    ) : (
      <div class="text-center py-12 bg-gray-50 rounded-lg">
        <h2 class="text-xl font-semibold mb-2">No reviews in this category yet</h2>
        <p class="text-gray-600 mb-6">
          Our experts are working on reviews for {category.data.name}. Check back soon!
        </p>
        <a href="/en/reviews" class="btn-primary">
          Browse All Reviews
        </a>
      </div>
    )}

    <!-- 分类描述（如果有更多内容） -->
    <div class="mt-12 pt-8 border-t">
      <h2 class="text-2xl font-bold mb-4">About {category.data.name}</h2>
      <div class="prose max-w-none">
        <p>
          Our {category.data.name} reviews are based on extensive testing by our team of experts. 
          We evaluate products based on performance, value, durability, and user experience to 
          help you find the best options for your needs.
        </p>
        <p>
          Whether you're looking for the latest technology or tried-and-true classics, 
          our reviews provide honest, unbiased recommendations you can trust.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.container {
  max-width: 1200px;
}
.btn-primary {
  @apply bg-primary-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-primary-700 transition-colors;
}
.prose p {
  margin-bottom: 1rem;
  line-height: 1.6;
}
</style>