---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RatingStars from '@/components/RatingStars.tsx';
import { getCollection } from 'astro:content';

const lang = 'en';

// 导出 getStaticPaths 函数
export async function getStaticPaths() {
  const allReviews = await getCollection('reviews');
  const englishReviews = allReviews.filter(review => review.data.lang === lang);
  
  return englishReviews.map((review) => ({
    params: { 
      slug: review.slug,
      lang: lang
    },
    props: { 
      review,
      lang
    },
  }));
}

// 通过 props 接收数据
const { review, lang: pageLang } = Astro.props;

// 获取相关评测（同类别，同语言）
const allReviews = await getCollection('reviews');
const englishReviews = allReviews.filter(r => r.data.lang === pageLang);
const relatedReviews = englishReviews
  .filter(r => 
    r.data.productCategory === review.data.productCategory && 
    r.slug !== review.slug
  )
  .slice(0, 3);
---

<BaseLayout 
  title={`${review.data.title} Review - Wirecutter Clone`}
  description={review.data.description}
  lang={pageLang}
>
  <div class="container mx-auto px-4 py-8">
    <!-- 面包屑导航 -->
    <nav class="text-sm text-gray-600 mb-6">
      <a href="/en" class="hover:text-blue-600">Home</a> &gt;
      <a href="/en/reviews" class="hover:text-blue-600">Reviews</a> &gt;
      <span class="text-gray-800">{review.data.title}</span>
    </nav>

    <!-- 评测标题和元信息 -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{review.data.title}</h1>
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <div class="flex items-center">
          <RatingStars rating={review.data.rating} />
          <span class="ml-2 font-semibold">{review.data.rating}/5</span>
          {review.data.ratingCount && (
            <span class="ml-2 text-gray-600">({review.data.ratingCount} reviews)</span>
          )}
        </div>
        <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">
          {review.data.productCategory}
        </span>
        <span class="text-gray-600">{review.data.publishDate.toLocaleDateString('en-US')}</span>
        <span class="text-gray-600">• {review.data.readTime} min read</span>
      </div>
      
      {review.data.coverImage && (
        <img 
          src={review.data.coverImage} 
          alt={review.data.title}
          class="w-full h-64 md:h-96 object-cover rounded-lg mb-6"
        />
      )}
    </div>

    <!-- 摘要 -->
    <div class="bg-gray-50 p-6 rounded-lg mb-8">
      <h2 class="text-xl font-bold mb-3">Summary</h2>
      <p class="text-gray-700">{review.data.description}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- 主要内容 -->
      <div class="lg:col-span-2">
        <div class="prose max-w-none">
          <h2>Detailed Review</h2>
          <slot />
        </div>
      </div>

      <!-- 侧边栏 -->
      <div class="space-y-6">
        <!-- 优缺点 -->
        <div class="bg-white border rounded-lg p-6">
          <h3 class="text-lg font-bold mb-4">Pros & Cons</h3>
          
          <div class="mb-4">
            <h4 class="font-semibold text-green-700 mb-2">Pros</h4>
            <ul class="list-disc pl-5 space-y-1">
              {review.data.pros.map((pro, index) => (
                <li key={index} class="text-gray-700">{pro}</li>
              ))}
            </ul>
          </div>
          
          <div>
            <h4 class="font-semibold text-red-700 mb-2">Cons</h4>
            <ul class="list-disc pl-5 space-y-1">
              {review.data.cons.map((con, index) => (
                <li key={index} class="text-gray-700">{con}</li>
              ))}
            </ul>
          </div>
        </div>

        <!-- 关键特性 -->
        {review.data.keyFeatures && review.data.keyFeatures.length > 0 && (
          <div class="bg-white border rounded-lg p-6">
            <h3 class="text-lg font-bold mb-4">Key Features</h3>
            <ul class="space-y-2">
              {review.data.keyFeatures.map((feature, index) => (
                <li key={index} class="flex items-start">
                  <span class="text-green-500 mr-2">✓</span>
                  <span class="text-gray-700">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- 规格 -->
        {review.data.specifications && Object.keys(review.data.specifications).length > 0 && (
          <div class="bg-white border rounded-lg p-6">
            <h3 class="text-lg font-bold mb-4">Specifications</h3>
            <dl class="space-y-2">
              {Object.entries(review.data.specifications).map(([key, value]) => (
                <div class="flex justify-between">
                  <dt class="text-gray-600">{key}:</dt>
                  <dd class="font-medium">{value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <!-- 价格 -->
        <div class="bg-white border rounded-lg p-6">
          <h3 class="text-lg font-bold mb-4">Price</h3>
          <div class="text-2xl font-bold text-gray-900 mb-2">
            {review.data.priceCurrency} {review.data.price.toFixed(2)}
          </div>
          {review.data.retailers && review.data.retailers.length > 0 && (
            <div class="mt-4">
              <h4 class="font-medium mb-2">Available at:</h4>
              <ul class="space-y-2">
                {review.data.retailers.slice(0, 3).map((retailer, index) => (
                  <li key={index} class="flex justify-between items-center">
                    <span class="text-gray-700">{retailer.name}</span>
                    <a 
                      href={retailer.url} 
                      target="_blank" 
                      class="text-primary-600 hover:text-primary-700 text-sm"
                    >
                      View
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- 相关评测 -->
    {relatedReviews.length > 0 && (
      <div class="mt-12">
        <h2 class="text-2xl font-bold mb-6">Related Reviews</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedReviews.map((related) => (
            <a 
              href={`/en/reviews/${related.slug}`}
              class="block border rounded-lg p-4 hover:shadow-md transition-shadow"
            >
              <h3 class="font-bold mb-2">{related.data.title}</h3>
              <div class="flex items-center mb-2">
                <RatingStars rating={related.data.rating} size="sm" />
                <span class="ml-2 text-sm">{related.data.rating}/5</span>
              </div>
              <p class="text-sm text-gray-600 line-clamp-2">{related.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
.container {
  max-width: 1200px;
}
.prose h2 {
  font-size: 1.5rem;
  font-weight: bold;
  margin-top: 2rem;
  margin-bottom: 1rem;
}
.prose p {
  margin-bottom: 1rem;
  line-height: 1.6;
}
</style>