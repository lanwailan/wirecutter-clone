---
const footerLinks = {
  'Categories': [
    { name: 'Electronics', href: '/electronics' },
    { name: 'Home & Garden', href: '/home-garden' },
    { name: 'Kitchen', href: '/kitchen' },
    { name: 'Sleep', href: '/sleep' },
    { name: 'Health & Fitness', href: '/health-fitness' },
  ],
  'Resources': [
    { name: 'About Us', href: '/about' },
    { name: 'How We Test', href: '/how-we-test' },
    { name: 'Contact', href: '/contact' },
    { name: 'Privacy Policy', href: '/privacy' },
    { name: 'Terms of Service', href: '/terms' },
  ],
  'Social': [
    { name: 'Twitter', href: 'https://twitter.com' },
    { name: 'Facebook', href: 'https://facebook.com' },
    { name: 'Instagram', href: 'https://instagram.com' },
    { name: 'YouTube', href: 'https://youtube.com' },
    { name: 'RSS', href: '/rss' },
  ]
};
---

<footer class="bg-gray-900 text-gray-300 mt-auto">
  <div class="container-custom">
    <div class="py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Brand -->
        <div class="lg:col-span-1">
          <div class="flex items-center space-x-2 mb-4">
            <div class="w-10 h-10 bg-primary-500 rounded-lg"></div>
            <span class="text-2xl font-bold text-white">Wirecutter<span class="text-primary-500">Clone</span></span>
          </div>
          <p class="text-gray-400 mb-6">
            Independent product reviews and buying advice you can trust.
          </p>
          <div class="flex space-x-4">
            <a href="#" class="text-gray-400 hover:text-white transition-colors">
              <span class="sr-only">Twitter</span>
              <div class="w-6 h-6 bg-gray-700 rounded-full"></div>
            </a>
            <a href="#" class="text-gray-400 hover:text-white transition-colors">
              <span class="sr-only">Facebook</span>
              <div class="w-6 h-6 bg-gray-700 rounded-full"></div>
            </a>
            <a href="#" class="text-gray-400 hover:text-white transition-colors">
              <span class="sr-only">Instagram</span>
              <div class="w-6 h-6 bg-gray-700 rounded-full"></div>
            </a>
          </div>
        </div>

        <!-- Links -->
        {Object.entries(footerLinks).map(([category, links]) => (
          <div>
            <h3 class="text-white font-semibold mb-4">{category}</h3>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  <a 
                    href={link.href} 
                    class="text-gray-400 hover:text-white transition-colors"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Newsletter -->
      <div class="mt-12 pt-8 border-t border-gray-800">
        <div class="max-w-md">
          <h3 class="text-white font-semibold mb-4">Stay Updated</h3>
          <p class="text-gray-400 mb-4">
            Get the latest product reviews and buying advice delivered to your inbox.
          </p>
          <form class="flex gap-2">
            <input
              type="email"
              placeholder="Your email address"
              class="flex-grow px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg 
                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                     focus:ring-primary-500 focus:border-transparent"
            />
            <button
              type="submit"
              class="btn-primary whitespace-nowrap"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-6 border-t border-gray-800">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-gray-500 text-sm">
          © {new Date().getFullYear()} WirecutterClone. All rights reserved.
        </p>
        <div class="flex items-center space-x-6 mt-4 md:mt-0">
          <a href="/sitemap" class="text-gray-500 hover:text-gray-300 text-sm">Sitemap</a>
          <a href="/accessibility" class="text-gray-500 hover:text-gray-300 text-sm">Accessibility</a>
          <a href="/cookies" class="text-gray-500 hover:text-gray-300 text-sm">Cookie Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>