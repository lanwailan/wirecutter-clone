  viewBox="0 0 20 20" 
  fill="none" 
  stroke="currentColor" 
  stroke-width="2"
  stroke-linecap="round" 
  stroke-linejoin="round"
>
  <line x1="4" y1="4" x2="16" y2="16" />
  <line x1="16" y1="4" x2="4" y2="16" />
</svg>